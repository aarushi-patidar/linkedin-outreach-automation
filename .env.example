# Recommended: attach to your real Chrome (avoids LinkedIn login loops)

AUTH_MODE=cdp

CDP_URL=http://127.0.0.1:9222

BROWSER_CHANNEL=chrome

HEADLESS=false

# Delay between profiles (milliseconds)
PROFILE_DELAY_MIN_MS=9000
PROFILE_DELAY_MAX_MS=9000

# AUTH_MODE=profile

# LINKEDIN_PROFILE_DIR=./.linkedin-profile



# Alternative: inject cookies (least reliable)

# AUTH_MODE=cookies

# LI_AT=your_li_at_cookie_value_here

# LINKEDIN_COOKIES_PATH=./linkedin-cookies.json

